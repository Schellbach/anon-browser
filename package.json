{
  "name": "anon-browser",
  "productName": "Anon",
  "version": "0.3.0",
  "description": "Anon Browser — privacy browser with a built-in Bitcoin Vault",
  "main": "src/main.js",
  "author": "Anon Computer, Inc.",
  "license": "MIT",
  "scripts": {
    "brand": "node scripts/brand-electron-app.js",
    "prestart": "node scripts/brand-electron-app.js",
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "predev": "node scripts/brand-electron-app.js",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron . --dev",
    "pack": "env -u ELECTRON_RUN_AS_NODE electron-builder --dir",
    "dist": "env -u ELECTRON_RUN_AS_NODE electron-builder --mac dmg",
    "test": "npm run test:unit && npm run test:electron",
    "test:unit": "node --test test/*.test.js",
    "test:electron": "node test/run-electron-smoke.js"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "build": {
    "appId": "computer.anon.browser",
    "productName": "Anon",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**",
      "renderer/**",
      "privacy/**",
      "vault/**",
      "brand/icon.png",
      "brand/icon.icns",
      "brand/fonts/**",
      "LICENSE",
      "TRADEMARKS.md",
      "package.json"
    ],
    "mac": {
      "icon": "brand/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "dmg": {
      "title": "Anon"
    }
  },
  "dependencies": {
    "@ghostery/adblocker": "^2.18.1",
    "@scure/base": "^2.0.0",
    "@scure/bip32": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "@scure/btc-signer": "^2.2.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "^26.15.3"
  }
}
